generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  username  String   @unique
  xp        Int      @default(0)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  scores    Score[]
  likes     Like[]
}

model Game {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  contentBody String?  @db.Text
  thumbnail   String
  previewVideo String?
  iframeUrl   String?  // Nullable for Shadow Pages
  category    Category? @relation(fields: [categoryId], references: [id])
  categoryId  String?
  tags        String[] @default([])
  controls    Json?    // e.g., { "wasd": "Move", "space": "Jump" }
  faq         Json?    // Array of { "q": "...", "a": "..." }
  trendScore  Float    @default(0)
  playCount   Int      @default(0)
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  scores       Score[]
  sectionItems SectionItem[]
  likes        Like[]
  seoPages     SeoPage[]
  mediaAssets  MediaAsset[]

  @@index([slug])
  @@index([playCount])
  @@index([trendScore])
}

model Category {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  seoContent String?  @db.Text
  games      Game[]
  createdAt  DateTime @default(now())
}

model SeoPage {
  id                String   @id @default(cuid())
  gameId            String
  slug              String   @unique // e.g., "play-slope-unblocked"
  modifier          String   // e.g., "unblocked", "fullscreen"
  customTitle       String?
  customDescription String?
  game              Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([gameId])
}

model MediaAsset {
  id        String   @id @default(cuid())
  gameId    String
  type      String   // 'image', 'video_embed', 'article_snippet'
  url       String
  title     String?
  content   String?  @db.Text
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([gameId])
}

model TrendingKeyword {
  id           String   @id @default(cuid())
  keyword      String   @unique
  searchVolume Int      @default(0)
  status       String   @default("detected") // 'detected', 'content_ready', 'game_live'
  lastUpdated  DateTime @default(now())
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model Score {
  id        String   @id @default(cuid())
  value     Int
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  game      Game     @relation(fields: [gameId], references: [id])

  @@index([gameId])
}

model Settings {
  id           String   @id @default("global")
  siteName     String   @default("PlayZ Arcade")
  defaultTheme String   @default("dark")
  adsTxt       String?  @default("gamepix.com, ZA727, DIRECT, f08c47fec0942fa0")
  autoBoostTrending Boolean @default(true)
  autoCreateShadowGames Boolean @default(true)
  updatedAt    DateTime @updatedAt
}

model Section {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  items     SectionItem[]
}

model SectionItem {
  id        String   @id @default(cuid())
  sectionId String
  gameId    String
  order     Int      @default(0)
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([sectionId, gameId])
}
